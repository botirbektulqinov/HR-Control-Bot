# --- Telegram ---
BOT_TOKEN=123456:PASTE_YOUR_TOKEN_HERE

# Telegram ID(lar) — super adminlar (vergul bilan). @userinfobot dan oling.
SUPER_ADMIN_IDS=123456789

# --- Database ---
# Docker compose ichida host = "db". Lokalda = "localhost".
DATABASE_URL=postgresql+asyncpg://hr:hr@db:5432/hr_control

# --- Attendance / Location ---
DEFAULT_TIMEZONE=Asia/Tashkent
# strict | medium | light  (spoofing himoyasi darajasi)
LOCATION_STRICTNESS=medium
# Yuborilgan joylashuv necha soniyagacha "yangi" hisoblanadi
LOCATION_MAX_AGE_SECONDS=120

# --- Dashboard API ---
